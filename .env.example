# Bring your own keys. Openfield routes to whichever provider you configure.
# You only need ONE to start.

# fal.ai — single key unlocks Seedance, Kling, Veo, Wan, Hunyuan, LTX, Minimax
FAL_KEY=

# Replicate — alt route for most of the same models + open weights
REPLICATE_API_TOKEN=

# Self-hosted / custom endpoint (your own Seedance/Wan/ComfyUI box)
# Must implement POST /create and GET /status/:id  (see src/providers/custom.ts)
OPENFIELD_CUSTOM_URL=
OPENFIELD_CUSTOM_KEY=
